{
  "name": "@scribble/server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "build": "prisma generate && tsc",
    "prestart": "prisma db push --accept-data-loss",
    "start": "node dist/app.js",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.1",
    "@fastify/jwt": "^9.0.1",
    "@prisma/client": "^6.4.1",
    "@scribble/shared": "*",
    "@socket.io/redis-adapter": "^8.3.0",
    "fastify": "^5.2.1",
    "ioredis": "^5.11.1",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "prisma": "^6.4.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  }
}
